# --- Build artifacts ---
/bin/
/dist/
# tmula skill artifacts (scaffold/enrich/run/triage write here): generated, not versioned.
/json/
*.exe
*.test
*.out
coverage.*
*.prof

# --- Go ---
/vendor/

# --- Node / web ---
web/node_modules/
web/dist/
node_modules/

# Built React UI assets copied into the embed dir (index.html placeholder stays tracked)
server/internal/web/static/assets/

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- OS ---
.DS_Store
Thumbs.db

# --- Local dev tooling (vskills / codex / omc) — not part of the product ---
# Remove these lines if you want to version the tooling/skills.
.omc/
# .claude/ is local-only EXCEPT the shipped tmula-* skills, the project hook
# (tmula-guard) and the settings that wire it (auto-discovered + versioned).
# Personal settings.local.json stays ignored.
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/skills/
.claude/skills/*
!.claude/skills/tmula-scaffold/
!.claude/skills/tmula-enrich/
!.claude/skills/tmula-run/
!.claude/skills/tmula-triage/
!.claude/skills/tmula-up/
.codex/
/context/
.vills-lock.json
/engine
/sample-api
