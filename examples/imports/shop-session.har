{
  "log": {
    "version": "1.2",
    "creator": { "name": "tmula-example", "version": "1.0" },
    "comment": "A recorded shopping session against the demo shop API. Import it to turn a real browser/proxy capture into a tmula scenario (cross-origin entries like analytics are dropped automatically).",
    "entries": [
      { "request": { "method": "GET",  "url": "http://localhost:9000/browse" }, "response": { "status": 200 } },
      { "request": { "method": "GET",  "url": "http://localhost:9000/search?q=shoes" }, "response": { "status": 200 } },
      { "request": { "method": "GET",  "url": "http://localhost:9000/product?id=7" }, "response": { "status": 200 } },
      { "request": { "method": "POST", "url": "http://localhost:9000/cart",
        "postData": { "mimeType": "application/json", "text": "{\"productId\":\"p7\",\"qty\":1}" } },
        "response": { "status": 200 } },
      { "request": { "method": "POST", "url": "http://localhost:9000/checkout",
        "postData": { "mimeType": "application/json", "text": "{\"total\":42}" } },
        "response": { "status": 200 } }
    ]
  }
}
